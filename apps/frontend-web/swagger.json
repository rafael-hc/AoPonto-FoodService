  "info": {
    "title": "AoPonto FoodService API",
    "description": "Documentação da API do sistema AoPonto",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    { "name": "users", "description": "" },
    { "name": "session", "description": "" }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": { "scheme": "bearer", "bearerFormat": "JWT", "type": "http" }
    },
    "schemas": {
      "RegisterUserDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "email": {
            "type": "string",
            "minLength": 1,
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "document": { "type": "string", "minLength": 1 },
          "login": { "type": "string", "minLength": 3 },
          "password": { "type": "string", "minLength": 6 },
          "role": { "type": "string", "enum": ["ADMIN", "CASHIER", "KITCHEN"] }
        },
        "required": ["name", "email", "document", "login", "password"]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "login": { "type": "string" },
          "role": { "type": "string", "enum": ["ADMIN", "CASHIER", "KITCHEN"] },
          "active": { "type": "boolean" },
          "name": { "type": "string" },
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "document": { "type": "string" },
          "contactId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          }
        },
        "required": [
          "id",
          "login",
          "role",
          "active",
          "name",
          "email",
          "document",
          "contactId"
        ]
      },
      "FetchUsersResponseDto": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid",
                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                },
                "login": { "type": "string" },
                "role": {
                  "type": "string",
                  "enum": ["ADMIN", "CASHIER", "KITCHEN"]
                },
                "active": { "type": "boolean" },
                "name": { "type": "string" },
                "email": {
                  "type": "string",
                  "format": "email",
                  "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
                },
                "document": { "type": "string" },
                "contactId": {
                  "type": "string",
                  "format": "uuid",
                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                }
              },
              "required": [
                "id",
                "login",
                "role",
                "active",
                "name",
                "email",
                "document",
                "contactId"
              ]
            }
          }
        },
        "required": ["users"]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "document": { "type": "string", "minLength": 1 },
          "login": { "type": "string", "minLength": 3 },
          "password": { "type": "string", "minLength": 6 },
          "role": { "type": "string", "enum": ["ADMIN", "CASHIER", "KITCHEN"] },
          "active": { "type": "boolean" }
        }
      },
      "RegisterProductDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "name": { "type": "string", "minLength": 1 },
          "price": { "type": "number", "minimum": 0 },
          "description": { "type": "string" },
          "costPrice": { "type": "number" },
          "minStock": { "type": "number" },
          "unitId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "kitchenId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "labelId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "productTypeId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          }
        },
        "required": [
          "code",
          "name",
          "price",
          "unitId",
          "labelId",
          "productTypeId"
        ]
      },
      "RegisterKitchenDto": {
        "type": "object",
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "ip": {
            "type": "string",
            "format": "ipv4",
            "pattern": "^(?:(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9][0-9]|[0-9])$"
          },
          "port": { "type": "string" },
          "printer": { "type": "string" },
          "versionReg": { "type": "number" },
          "versionSync": { "type": "number" }
        },
        "required": ["description", "ip", "port", "printer"]
      },
      "SingleKitchenResponseDto": {
        "type": "object",
        "properties": {
          "kitchen": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
              },
              "description": { "type": "string" },
              "ip": { "type": "string" },
              "port": { "type": "string" },
              "printer": { "type": "string" },
              "versionReg": { "type": "number", "nullable": true },
              "versionSync": { "type": "number", "nullable": true },
              "createdAt": {},
              "updatedAt": { "anyOf": [{}, { "type": "null" }] }
            },
            "required": [
              "id",
              "description",
              "ip",
              "port",
              "printer",
              "createdAt"
            ],
            "x-nestjs_zod-has-null": true,
            "x-nestjs_zod-self-required": true
          }
        },
        "required": ["kitchen"]
      },
      "FetchKitchensResponseDto": {
        "type": "object",
        "properties": {
          "kitchens": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid",
                  "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                },
                "description": { "type": "string" },
                "ip": { "type": "string" },
                "port": { "type": "string" },
                "printer": { "type": "string" },
                "versionReg": { "type": "number", "nullable": true },
                "versionSync": { "type": "number", "nullable": true },
                "createdAt": {},
                "updatedAt": { "anyOf": [{}, { "type": "null" }] }
              },
              "required": [
                "id",
                "description",
                "ip",
                "port",
                "printer",
                "createdAt"
              ]
            },
            "x-nestjs_zod-has-null": true
